# Server Configuration
PORT=3001
NODE_ENV=development
SESSION_SECRET=your-session-secret-here

# Google OAuth (Brandeis SSO)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# LINKA FleetView API
LINKA_API_BASE_URL=https://api.linkalock.com/v1
LINKA_API_KEY=your-linka-api-key
LINKA_API_SECRET=your-linka-api-secret

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Bike Inventory (JSON array of bike IDs for prototype)
BIKE_IDS=["bike-001","bike-002","bike-003"]
