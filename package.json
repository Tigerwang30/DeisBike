{
  "name": "deisbikes",
  "version": "1.0.0",
  "description": "DeisBikes - Brandeis University Bike Share System",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run api\" \"npm run client\"",
    "api": "./.venv/bin/uvicorn api.index:app --reload --port 3001",
    "test": "./.venv/bin/pytest",
    "test:diagnose": "./.venv/bin/python tests/diagnostics/test_api_diagnosis.py",
    "client": "cd client && npm run dev",
    "setup": "npm install --prefix client && python3 -m venv .venv && ./.venv/bin/pip install -r requirements.txt",
    "build": "npm run build --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
